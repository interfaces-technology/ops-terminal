# Linear — Settings → API → Personal API keys
LINEAR_API_KEY=

# Notion — https://www.notion.so/my-integrations
NOTION_API_KEY=

# Optional: comma-separated team keys (default: LAB,PLAY)
# LINEAR_TEAM_KEYS=LAB,PLAY

# Optional: gate the dashboard behind a shared access password (set in Vercel envs).
# ACCESS_PASSWORD=

# Vercel deploy — add Upstash Redis from Vercel Marketplace (auto-sets these).
# Local dev falls back to .data/cache.json when unset.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
