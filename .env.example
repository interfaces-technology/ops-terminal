# Notion — personal access token (Developer portal → Personal access tokens)
# Uses your Notion permissions; no per-page Connections sharing needed.
NOTION_API_KEY=

# Optional: gate the dashboard behind a shared access password (set in Vercel envs).
# ACCESS_PASSWORD=

# Vercel deploy — add Upstash Redis from Vercel Marketplace (auto-sets these).
# Local dev falls back to .data/cache.json when unset.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
