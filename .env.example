# App runtime (required)
# Notion — personal access token (Developer portal → Personal access tokens)
# Uses your Notion permissions; no per-page Connections sharing needed.
NOTION_API_KEY=

# App runtime (optional) — gate the dashboard behind a shared access password.
# ACCESS_PASSWORD=

# Optional infra — Upstash Redis on Vercel Marketplace (auto-sets these).
# Not GitHub. Local dev falls back to .data/cache.json when unset.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
